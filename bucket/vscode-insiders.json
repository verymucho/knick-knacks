{
    "version": "1.130.0-1784611211376",
    "description": "Visual Studio Code is a lightweight but powerful source code editor (Insiders, Portable Edition).",
    "homepage": "https://code.visualstudio.com/",
    "license": {
        "identifier": "Freeware",
        "url": "https://code.visualstudio.com/License/"
    },
    "notes": [
        "Add Visual Studio Code as a context menu option by running:",
        "  reg import \"$dir\\install-context.reg\"",
        "For file associations, run:",
        "  reg import \"$dir\\install-associations.reg\"",
        "For github integration, run:",
        "  reg import \"$dir\\install-github-integration.reg\""
    ],
    "architecture": {
        "64bit": {
            "url": [
                "https://vscode.download.prss.microsoft.com/dbazure/download/insider/0e04915922a9556b77ceae50a86a9d5ee9a61371/VSCode-win32-x64-1.130.0-insider.zip",
                "https://vscode.download.prss.microsoft.com/dbazure/download/insider/0e04915922a9556b77ceae50a86a9d5ee9a61371/vscode_cli_win32_x64_cli.zip"
            ],
            "hash": [
                "a74e5e9b7a335c6f6c807d39847cd45515ee3bebd877a7aa39508eb565a6b129",
                "dccab12d75891c640b346600ae50d7e707116177ef3c65c32f9a13df571e8008"
            ]
        },
        "arm64": {
            "url": [
                "https://vscode.download.prss.microsoft.com/dbazure/download/insider/0e04915922a9556b77ceae50a86a9d5ee9a61371/VSCode-win32-arm64-1.130.0-insider.zip",
                "https://vscode.download.prss.microsoft.com/dbazure/download/insider/0e04915922a9556b77ceae50a86a9d5ee9a61371/vscode_cli_win32_arm64_cli.zip"
            ],
            "hash": [
                "d720522d88f4f841cf00fc2960cdbbad71a3d93317af2f2f313d4291c8a51ddb",
                "91750b32f5fbdb989d93490d3e78050677e68afed35dd422aec20e2bb9a2e36f"
            ]
        }
    },
    "extract_to": [
        ".",
        "bin"
    ],
    "post_install": [
        "$dir = (Get-Item \"$dir\").ResolvedTarget",
        "$build_dir = Get-ChildItem \"$dir\" -Directory | Where-Object { $_.Name -match '^[a-f0-9]{10,}$' } | Select-Object -First 1 -ExpandProperty FullName",
        "$dirpath = \"$dir\".Replace('\\', '\\\\')",
        "$exepath = \"$dir\\Code - Insiders.exe\".Replace('\\', '\\\\')",
        "'install-associations', 'uninstall-associations', 'install-context', 'uninstall-context', 'install-github-integration', 'uninstall-github-integration' | ForEach-Object {",
        "  if (Test-Path \"$bucketsdir\\extras\\scripts\\vscode\\$_.reg\") {",
        "    $content = Get-Content \"$bucketsdir\\extras\\scripts\\vscode\\$_.reg\"",
        "    $content = $content.Replace('$codedir', $dirpath)",
        "    $content = $content.Replace('$code', $exepath)",
        "    $content = $content.Replace('&Code', 'Code &Insiders')",
        "    $content = $content.Replace('771FD6B0-FA20-440A-A002-3B3BAC16DC50', '217B4C08-948D-4276-BFBB-BEE930AE5A2C')",
        "    $content = $content.Replace('Microsoft Visual Studio Code', 'Microsoft Visual Studio Code Insiders')",
        "    if ($global) {",
        "      $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE')",
        "    }",
        "    $content | Set-Content -Path \"$dir\\$_.reg\"",
        "  }",
        "}",
        "Get-ChildItem $dir -File -Filter install-*.reg | ForEach-Object { reg import $_.FullName >nul 2>&1 }",
        "if (!(Test-Path \"$dir\\bin\\code.cmd\") -and (Test-Path \"$dir\\bin\\code-insiders.cmd\")) {",
        "    New-Item -ItemType SymbolicLink -Path \"$dir\\bin\\code.cmd\" -Value \"$dir\\bin\\code-insiders.cmd\" | Out-Null",
        "}",
        "if ($build_dir -and (Test-Path \"$build_dir\\resources\")) {",
        "    New-Item -ItemType Junction -Path \"$dir\\resources\" -Target \"$build_dir\\resources\" | Out-Null",
        "}",
        "if (Test-Path \"$dir\\bin\\code-insiders.exe\") { & \"$dir\\bin\\code-insiders.exe\" version use insider --install-dir \"$dir\" }",
        "if (!(Test-Path \"$dir\\data\\extensions\") -and (Test-Path \"$env:USERPROFILE\\.vscode-insiders\\extensions\")) {",
        "    info '[Portable Mode] Copying extensions...'",
        "    Copy-Item \"$env:USERPROFILE\\.vscode-insiders\\extensions\" \"$dir\\data\" -Recurse",
        "}",
        "if (!(Test-Path \"$dir\\data\\user-data\") -and (Test-Path \"$env:AppData\\Code - Insiders\")) {",
        "    info '[Portable Mode] Copying user data...'",
        "    Copy-Item \"$env:AppData\\Code - Insiders\" \"$dir\\data\\user-data\" -Recurse",
        "}",
        "$extensions_file = \"$dir\\data\\extensions\\extensions.json\"",
        "if ((Test-Path \"$extensions_file\")) {",
        "    info 'Adjusting path in extensions file...'",
        "    (Get-Content \"$extensions_file\") -replace '(?<=vscode-insiders(/|\\\\\\\\)).*?(?=(/|\\\\\\\\)data(/|\\\\\\\\)extensions)', $version | Set-Content \"$extensions_file\"",
        "}"
    ],
    "env_add_path": "bin",
    "shortcuts": [
        [
            "Code - Insiders.exe",
            "Visual Studio Code - Insiders"
        ]
    ],
    "persist": "data",
    "uninstaller": {
        "script": [
            "if ($cmd -eq 'uninstall') {",
            "    Get-ChildItem $dir -File -Filter uninstall-*.reg | ForEach-Object {",
            "       reg import $_.FullName >nul 2>&1",
            "    }",
            "}"
        ]
    },
    "checkver": {
        "url": "https://update.code.visualstudio.com/api/update/win32-x64-archive/insider/latest",
        "script": [
            "$release = $page | ConvertFrom-Json -ErrorAction Stop",
            "Write-Output \"$($release.url), $($release.timestamp)\""
        ],
        "regex": "insider/(?<commit>[^/]+)/VSCode-win32-x64-(?<prefix>[\\d.]+)[^\\d]+(?<suffix>[\\d.]+)",
        "replace": "${prefix}-${suffix}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": [
                    "https://vscode.download.prss.microsoft.com/dbazure/download/insider/$matchCommit/VSCode-win32-x64-$matchHead-insider.zip",
                    "https://vscode.download.prss.microsoft.com/dbazure/download/insider/$matchCommit/vscode_cli_win32_x64_cli.zip"
                ],
                "hash": {
                    "mode": "json",
                    "jsonpath": "$..products[?(@.url == '$url')].sha256hash",
                    "url": "https://code.visualstudio.com/sha?build=insider"
                }
            },
            "arm64": {
                "url": [
                    "https://vscode.download.prss.microsoft.com/dbazure/download/insider/$matchCommit/VSCode-win32-arm64-$matchHead-insider.zip",
                    "https://vscode.download.prss.microsoft.com/dbazure/download/insider/$matchCommit/vscode_cli_win32_arm64_cli.zip"
                ],
                "hash": {
                    "mode": "json",
                    "jsonpath": "$..products[?(@.url == '$url')].sha256hash",
                    "url": "https://code.visualstudio.com/sha?build=insider"
                }
            }
        }
    }
}
