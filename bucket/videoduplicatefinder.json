{
    "version": "4.0-7b9b467",
    "description": "Cross-platform software to find duplicated video (and image) files on hard disk based on similiarity.",
    "homepage": "https://github.com/0x90d/videoduplicatefinder",
    "license": "GPLv3",
    "suggest": {
        "ffmpeg": "ffmpeg-shared"
    },
    "architecture": {
        "64bit": {
            "url": [
                "https://github.com/0x90d/videoduplicatefinder/releases/download/4.0.x/GUI-win-x64.zip",
                "https://github.com/0x90d/videoduplicatefinder/releases/download/4.0.x/CLI-win-x64.zip"
            ],
            "hash": [
                "e3d49aa11f4f9844002500da6ff39c8d31959b28207e0689a81cb76a9f7a847e",
                "4915f983f0b31eede47094e2ffc263a386f0d547923b7f5dde5e3e0dd0eb24cd"
            ]
        }
    },
    "bin": "vdf-cli.exe",
    "shortcuts": [
        [
            "VDF.GUI.exe",
            "Video Duplicate Finder"
        ]
    ],
    "pre_install": "if (!(Test-Path \"$persist_dir\\Settings.json\")) { Set-Content -Encoding ASCII -Path \"$dir\\Settings.json\" -Value '{\"CustomDatabaseFolder\":\"data\"}' }",
    "persist": [
        "Settings.json",
        "bin",
        "data"
    ],
    "checkver": {
        "github": "https://api.github.com/repos/0x90d/videoduplicatefinder/releases/tags/4.1.x",
        "jsonpath": "$..body",
        "regex": "Last build based on ([0-9a-f]{7})",
        "replace": "4.1-${1}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": [
                    "https://github.com/0x90d/videoduplicatefinder/releases/download/4.1.x/GUI-win-x64.zip",
                    "https://github.com/0x90d/videoduplicatefinder/releases/download/4.1.x/CLI-win-x64.zip"
                ]
            }
        }
    }
}
