            ],
            "hash": [
                "59195d849ebe6aef3a87fd86bc0a8d70df7b5998dd7ddafaa04b6e3df9c35d63",
                "4da116e2e4b6068b668c243a1ea44e7d5dbd288510a0aafaf6e9b2eb4b3b3ea4"
            ]
        }
    },
    "bin": "vdf-cli.exe",
    "shortcuts": [
        [
            "VDF.GUI.exe",
            "Video Duplicate Finder"
        ]
    ],
    "pre_install": "if (!(Test-Path \"$persist_dir\\Settings.json\")) { Set-Content -Encoding ASCII -Path \"$dir\\Settings.json\" -Value '{\"CustomDatabaseFolder\":\"data\"}' }",
